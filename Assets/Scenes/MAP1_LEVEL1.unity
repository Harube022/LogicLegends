  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Welcome Student to the First Stage!\r\n\r\nThis stage is called the Truth
    Table Stage, to complete this stage\r\n\r\n\u2022 You must find the correct blocks
    inside the houses\r\n\u2022 Place the correct blocks in the Truth Table in the
    correct column and order\r\n\u2022 And complete all 3 challenges within this
    stage\r\n\n\r\nThis Truth Table Stage consist of three challenges with different
    difficulty levels:\r\n\r\n\u2022 Challenge 1 \u2013 Easy\r\n\u2022 Challenge
    2 \u2013 Normal\r\n\u2022 Challenge 3 \u2013 Hard\r\n\n\r\nIf you look at the
    upper-right corner of the screen, you will see 3 Hearts.\n\r\nThese hearts represent
    your chances. If you make a mistake, you will lose one Heart.\n\r\nMistakes include:\n\r\n\u2022
    Placing the wrong block in the Truth Table\r\n\u2022 Placing a block in the wrong
    column\r\n\u2022 Placing blocks in the wrong order\r\n\r\nIf you lose all your
    Hearts, the game will be over.\r\n\n\r\nOnce you successfully complete all 3
    challenges, a portal will open, allowing you to proceed to the next stage.\r\n\r\nGood
    luck, and prove your logic skills!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: b86979d84307d064da1c84f6fcc3eb3e, type: 2}
